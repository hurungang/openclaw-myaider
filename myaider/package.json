{
  "name": "@myaider/myaider",
  "version": "1.0.10",
  "description": "OpenClaw plugin for MyAider MCP integration — connect to myaider.ai MCP, invoke tools, and import dynamic skills into OpenClaw.",
  "type": "module",
  "main": "src/index.js",
  "files": [
    "src",
    "skills",
    "skills-dynamic",
    "openclaw.plugin.json",
    "README.md",
    "TESTING.md"
  ],
  "keywords": [
    "openclaw",
    "plugin",
    "mcp",
    "model-context-protocol",
    "myaider",
    "skills"
  ],
  "homepage": "https://www.myaider.ai/mcp",
  "author": "MyAider",
  "license": "MIT",
  "engines": {
    "node": ">=22"
  },
  "peerDependencies": {
    "openclaw": ">=2026.3.12"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.26.0"
  },
  "scripts": {
    "test": "node --test test/http-transport.test.js test/manager.test.js",
    "prepare": "echo 'No build step required (ESM JS)'"
  },
  "openclaw": {
    "build": {
      "openclawVersion": "2026.3.12",
      "pluginSdkVersion": "2026.3.12"
    },
    "compat": {
      "pluginApi": ">=2026.3.12",
      "minGatewayVersion": "2026.3.12"
    },
    "extensions": [
      "./src/index.js"
    ]
  }
}
